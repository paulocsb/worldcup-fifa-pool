# Frontend environment (Vite) — public keys only.
#
# These values are exposed to the browser, so use ONLY public anon keys here.
# Never put service_role keys or API-Football keys in this file —
# those belong in supabase/functions/.env (also not committed).
#
# Copy this file to .env.local and fill in the values:
#   cp .env.example .env.local
#
# LOCAL development:
#   1. Run `supabase start` first
#   2. Then `supabase status --output env` and copy VITE_SUPABASE_URL + ANON_KEY
#
# PRODUCTION (Cloudflare Pages):
#   - Set these as environment variables in the Cloudflare dashboard:
#     Settings → Environment variables → Production
#   - Use your remote Supabase project's URL and anon key (Settings → API)

VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=

# Required for the Cloudflare Pages build to work with Vite 6 + the
# auto-injected @cloudflare/vite-plugin (requires Node 22+).
NODE_VERSION=22
