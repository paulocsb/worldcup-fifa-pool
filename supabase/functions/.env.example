# Edge functions environment — server-only secrets.
#
# Copy this file to supabase/functions/.env (NOT committed):
#   cp supabase/functions/.env.example supabase/functions/.env
#
# After editing, restart Supabase so the edge runtime picks up the values:
#   supabase stop && supabase start
#
# Variables:
#
# API_FOOTBALL_KEY — your API key from https://www.api-football.com
# Free tier allows ~100 req/day, enough for local development setup.
# For production, the Pro plan ($19/month) is required for unlimited
# 2026 season data.
API_FOOTBALL_KEY=

# League ID and season — these are the World Cup 2026.
# Do NOT change unless you're forking the app for a different tournament.
API_FOOTBALL_LEAGUE_ID=1
API_FOOTBALL_SEASON=2026
